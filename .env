# ----------------------------------------------------
# TELEGRAM QUIZ BOT CONFIGURATION ENVIRONMENT VARIABLES
# ----------------------------------------------------

# 1. Aapka Telegram Bot API Token जो @BotFather se mila hai
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRstUVwxyZ_12345678

# 2. Aapke bot ka exact username (bina @ ke)
BOT_USERNAME=OfficialQuizCloneBot

# 3. Default countdown timer (in seconds) har sawaal ke liye
TIMER_SECONDS=30

# 4. Database Storage Directory 
# Local PC par check karne ke liye ise "." (current folder) rehne dein.
# Cloud Server (Render/Railway) par persistent volume ke liye badalkar "/data" kar dein.
DATABASE_DIR=.
